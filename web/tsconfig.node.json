{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": ".tsbuild/node",
    "tsBuildInfoFile": ".tsbuild/node/.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
