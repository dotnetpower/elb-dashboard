{
  "name": "elb-dashboard-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "e2e:list": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts --list",
    "e2e:ui": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts --project ui-mock",
    "e2e:api": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts --project api-smoke",
    "e2e:mutation": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts --project mutation-mock",
    "e2e:azure": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts --project azure-lifecycle",
    "e2e:all-safe": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts --project ui-mock --project api-smoke --project mutation-mock",
    "e2e:dashboard": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/dashboard-smoke.spec.ts",
    "e2e:api-blast": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/api-blast-submit-smoke.spec.ts",
    "e2e:azure-core-nt-lifecycle": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/azure-core-nt-lifecycle.spec.ts",
    "e2e:new-search": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/new-search-options-matrix.spec.ts",
    "e2e:platform": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/platform-flows.api.spec.ts",
    "e2e:platform-aks": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/platform-flows.api.spec.ts --grep scenario:aks-lifecycle",
    "e2e:platform-sb": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/platform-flows.api.spec.ts --grep scenario:service-bus",
    "e2e:platform-blast": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/platform-flows.api.spec.ts --grep scenario:api-blast",
    "e2e:platform-queue": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/platform-flows.api.spec.ts --grep scenario:queue-parallel",
    "e2e:platform-perms": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts ../scripts/e2e/scenarios/platform-flows.api.spec.ts --grep scenario:permissions",
    "e2e:all": "NODE_PATH=./node_modules playwright test -c playwright.e2e.config.ts",
    "e2e:install-browsers": "playwright install chromium"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.27.0",
    "@azure/msal-react": "^2.2.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@microsoft/applicationinsights-react-js": "^17.3.6",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@tanstack/react-query": "^5.59.20",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
