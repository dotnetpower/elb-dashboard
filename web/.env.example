VITE_API_BASE_URL=http://localhost:8085
VITE_AUTH_DEV_BYPASS=true
VITE_AZURE_TENANT_ID=common
# Leave empty for local dev; `scripts/dev/local-run.sh web` will auto-fill from
# `azd env get-values` (API_CLIENT_ID) when this is unset. For a clone-and-run
# without azd, set it to the Entra App Registration's clientId.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:8090
