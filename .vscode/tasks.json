{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "server: start",
      "detail": "Launch the host-mode local control plane in detached background processes and return immediately.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LOCAL_LOG_CONSOLE": "false" }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": true
      }
    },
    {
      "label": "server: restart",
      "detail": "Stop local ELB servers, then launch the host-mode control plane in detached background processes.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["restart"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LOCAL_LOG_CONSOLE": "false" }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": true
      }
    },
    {
      "label": "server: stop",
      "detail": "Stop host-mode servers, local compose stacks, Redis, and Azurite for this repo.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["stop"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "server: status",
      "detail": "Show whether the host-mode local control plane services are running.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["status"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "redis: ensure",
      "detail": "Start a local Redis container on 127.0.0.1:6379 (idempotent). Used by worker/beat.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["redis"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": true
      }
    },
    {
      "label": "redis: stop",
      "detail": "Stop and remove the local Redis container.",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "docker rm -f elb-dev-redis >/dev/null 2>&1 && echo 'redis stopped' || echo 'redis was not running'"
      ],
      "problemMatcher": []
    },
    {
      "label": "api: start",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["api"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LOCAL_LOG_CONSOLE": "false" }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "echo": false,
        "showReuseMessage": false,
        "focus": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Will watch for changes",
          "endsPattern": "Application startup complete"
        }
      }
    },
    {
      "label": "worker: start",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["worker"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LOCAL_LOG_CONSOLE": "false" }
      },
      "dependsOn": ["redis: ensure"],
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "echo": false,
        "showReuseMessage": false,
        "focus": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "celery@",
          "endsPattern": "ready\\."
        }
      }
    },
    {
      "label": "beat: start",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["beat"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LOCAL_LOG_CONSOLE": "false" }
      },
      "dependsOn": ["redis: ensure"],
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "echo": false,
        "showReuseMessage": false,
        "focus": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "celery beat",
          "endsPattern": "Scheduler: Sending due task|beat: Starting"
        }
      }
    },
    {
      "label": "web: dev",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["web"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LOCAL_LOG_CONSOLE": "false" }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "echo": false,
        "showReuseMessage": false,
        "focus": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "press h \\+ enter to show help"
        }
      }
    },
    {
      "label": "terminal-exec: start",
      "detail": "Start the local loopback exec server on 127.0.0.1:7682 so api/worker can run azcopy/kubectl/elastic-blast locally.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["terminal-exec"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LOCAL_LOG_CONSOLE": "false" }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "echo": false,
        "showReuseMessage": false,
        "focus": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "exec_server_started",
          "endsPattern": "exec_server_started"
        }
      }
    },
    {
      "label": "fullstack: start",
      "detail": "Start the host-mode local control plane through the detached server launcher.",
      "dependsOn": ["server: start"],
      "problemMatcher": []
    },
    {
      "label": "fullstack: compose start",
      "detail": "Start the full 6-sidecar Container Apps layout locally with Docker Compose on http://127.0.0.1:18080/.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["compose-full", "--", "up", "-d", "--build"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "fullstack: compose stop",
      "detail": "Stop the local 6-sidecar Docker Compose stack.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["compose-full", "--", "down", "--remove-orphans"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "backend: start (api+worker+beat)",
      "dependsOn": ["api: start", "worker: start", "beat: start"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "tests: pytest",
      "detail": "Fast dev loop: parallel (-n auto), excludes 'slow' and 'subprocess' marked tests. ~3-5x faster than serial.",
      "type": "shell",
      "command": "uv run pytest -q api/tests",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        }
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "tests: full",
      "detail": "Full suite including 'slow' and 'subprocess' marked tests. Run before PRs touching shell scripts or BLAST comparison helpers.",
      "type": "shell",
      "command": "uv run pytest api/tests -m ''",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        }
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "tests: slow-only",
      "detail": "Run only 'slow' and 'subprocess' marked tests (the ones excluded from the default dev loop).",
      "type": "shell",
      "command": "uv run pytest api/tests -m 'slow or subprocess'",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        }
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "smoke: api",
      "detail": "Run scripts/dev/smoke_api.py against the local api on 127.0.0.1:8085.",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/dev/local-run.sh",
      "args": ["smoke"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "lint: ruff",
      "type": "shell",
      "command": "uv run ruff check api",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
