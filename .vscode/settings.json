{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit"
    }
  },
  "ms-python.isort.enable": false,
  "isort.check": false,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["api/tests"],

  // ─── Performance: stop watching / indexing heavy paths ────────────────────
  // Reason: docs/temp (535MB / 528 files), .venv (483MB), web/node_modules
  // (205MB), .logs, web/dist are all in .gitignore, but VS Code's file
  // watcher and language servers (Pylance, tsserver) do NOT honor .gitignore
  // on their own — they need explicit excludes.
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/.logs/**": true,
    "**/docs/temp/**": true,
    "**/web/dist/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.azurite/**": true,
    "**/__pycache__/**": true,
    "**/*.tsbuildinfo": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/.logs": true,
    "**/docs/temp": true,
    "**/web/dist": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.azurite": true,
    "**/__pycache__": true,
    "**/*.tsbuildinfo": true,
    "**/uv.lock": true,
    "**/package-lock.json": true
  },
  // Hide pure-cache / build artefacts from the Explorer tree only.
  // (Do NOT hide .venv, node_modules, .logs, docs/temp — devs still need
  // to open them occasionally.)
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.azurite": true,
    "**/__pycache__": true,
    "**/*.tsbuildinfo": true
  },

  // ─── Pylance ──────────────────────────────────────────────────────────────
  // Index only first-party code; skip stdlib copies in .venv and dumping
  // grounds like docs/temp.
  "python.analysis.exclude": [
    "**/.venv/**",
    "**/node_modules/**",
    "**/docs/temp/**",
    "**/.logs/**",
    "**/web/dist/**",
    "**/.pytest_cache/**",
    "**/.ruff_cache/**",
    "**/__pycache__/**"
  ],
  "python.analysis.indexing": true,
  "python.analysis.userFileIndexingLimit": 2000,

  // ─── TypeScript / tsserver ────────────────────────────────────────────────
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "excludeDirectories": ["**/node_modules", "**/dist", "**/.logs"]
  },

  // ─── Git scanner ──────────────────────────────────────────────────────────
  "git.repositoryScanIgnoredFolders": [
    "node_modules",
    ".venv",
    "docs/temp",
    ".logs",
    "web/dist",
    ".pytest_cache",
    ".ruff_cache"
  ],

  // ─── Integrated terminal: keep chatty background tasks light ──────────────
  // Long-running tasks (api/worker/beat/web/terminal-exec) write to
  // .logs/local/latest/*.log and skip console mirroring via LOCAL_LOG_CONSOLE=false.
  // These limits cap memory if something does emit output, and pick the most
  // efficient renderer to avoid hangs.
  "terminal.integrated.scrollback": 500,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "never"
}
