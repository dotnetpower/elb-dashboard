# Keep `az acr build` upload size small.
# These directories are huge build artifacts that the Dockerfiles do not need
# (api_app/Dockerfile installs deps from requirements.txt; web/Dockerfile
# runs `npm ci` inside the build image).
**/__pycache__
**/*.pyc
**/*.pyo
**/.git
**/.gitignore
**/.venv
.venv
.azure
.pytest_cache
.ruff_cache
.mypy_cache
**/node_modules
api/.python_packages
**/.python_packages
docs
infra/legacy
*.zip
*.tgz
*.tar.gz
*.log
