# =============================================================================
#  .env.example — LOCAL DEBUG ONLY
# =============================================================================
# This file documents the environment variables the host-mode local control
# plane (scripts/dev/local-run.sh, the "fullstack: start" VS Code task, and
# direct `uv run uvicorn ...` / `uv run celery ...` invocations) reads from
# `.env` at the repo root.
#
#  * It is NOT used in the deployed Azure Container App. The deployed image
#    receives configuration from Bicep (`infra/`) + `azd env` + Key Vault.
#  * It is NOT loaded by pytest or by any production code path.
#  * It is NOT the source of truth for anything that runs in cloud — see
#    `azd env get-values` for the deployed values.
#
# To use:
#   1. Copy this file to `.env` (gitignored).
#   2. Replace placeholder GUIDs with values from your tenant / `azd env`.
#   3. Keep AUTH_DEV_BYPASS=true unless you are explicitly debugging MSAL
#      locally (use `scripts/dev/local-run.sh auth-on` for that flow).
#
# Real subscription, tenant, and client ids belong in `.env` and `azd env`
# only — this example file must contain placeholders.
# =============================================================================

# --- Azure context (read by scripts/dev/local-run.sh) --------------------
# Used to validate `az account show` matches the expected sub/tenant before
# launching local services. Also surfaced to the api/worker so SDK calls
# bound to `DefaultAzureCredential` pick the right tenant.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# --- API auth ------------------------------------------------------------
# When true, /api/* skips MSAL bearer validation and returns a synthetic
# "anonymous" identity. This is the default local mode.
#
# To debug as your real `az login` identity, do NOT flip this by hand —
# run `scripts/dev/local-run.sh auth-on` (composes RBAC grant + storage
# firewall open + this flag + restart), and `auth-off` to revert.
AUTH_DEV_BYPASS=true
# Mirror flag consumed by the SPA dev server (web/.env.local). Kept in sync
# by the auth-on/off helper.
VITE_AUTH_DEV_BYPASS=true

# Required when AUTH_DEV_BYPASS=false (real-token mode). Auto-pulled from
# `azd env get-values` by local-debug-auth.sh; set manually if you do not
# use azd locally.
# API_CLIENT_ID=00000000-0000-0000-0000-000000000000

# --- Logging / docs ------------------------------------------------------
LOG_LEVEL=DEBUG
# Wire-level Azure SDK traces. Leave at WARNING unless actively debugging.
# AZURE_LOG_LEVEL=WARNING
ENABLE_DOCS=true
MAX_REQUEST_BODY_BYTES=10485760

# --- Local server ports (optional overrides) -----------------------------
# Host-mode defaults from scripts/dev/local-run.sh. Change only if these
# ports collide with another local process.
# API_HOST=127.0.0.1
# API_PORT=8085

# --- Celery (matches `scripts/dev/local-run.sh redis`) -------------------
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
OPS_REDIS_URL=redis://127.0.0.1:6379/2

# --- Terminal exec channel ----------------------------------------------
# Only needed if you also run `scripts/dev/local-run.sh terminal-exec`
# (or the full 6-sidecar compose stack) so api/worker can shell out to
# azcopy / kubectl / elastic-blast locally. The exec_server binds
# 127.0.0.1 only; the token is compared via hmac.compare_digest and must
# be >=16 chars or the api refuses to boot.
EXEC_TOKEN=dev-exec-token-not-secret-but-long-enough-for-startup-check
TERMINAL_EXEC_UPSTREAM=http://127.0.0.1:7682
TERMINAL_UPSTREAM=http://127.0.0.1:7681
FRONTEND_UPSTREAM=http://127.0.0.1:8081

# --- Local Storage debug (optional) --------------------------------------
# Used by `scripts/dev/local-run.sh storage-on|storage-off|auth-on` to
# temporarily open the workload Storage firewall to your laptop IP, and
# by the api/worker to talk to deployed Storage over private endpoints'
# public counterpart while debugging. Auto-resolved from `azd env`
# (STORAGE_ACCOUNT_NAME / AZURE_RESOURCE_GROUP) when unset.
#
# REMINDER: production Storage is `publicNetworkAccess: Disabled`. Never
# leave the firewall open after debugging — `storage-off` / `auth-off`
# restores the closed state. See .github/copilot-instructions.md §9.
# ELB_LOCAL_STORAGE_ACCOUNT=elbstg01
# ELB_LOCAL_STORAGE_RG=rg-elb-01
# AZURE_TABLE_ENDPOINT=https://elbstg01.table.core.windows.net
# AZURE_BLOB_ENDPOINT=https://elbstg01.blob.core.windows.net
# LOCAL_DEBUG_AUTO_OPEN_STORAGE=true
