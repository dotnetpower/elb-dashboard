# Local debug environment variables.
# Copy to .env and adjust. Keep real subscription, tenant, and client ids in
# .env / azd env only; this example file must contain placeholders.

# --- Azure (read-only by default; uses MI in cloud) -----------------------
# Required only if you want to test Azure SDK calls locally with `az login`.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_ID=

# --- API auth ------------------------------------------------------------
# When true, /api/* skips MSAL bearer validation and returns a synthetic
# identity. Use ONLY locally. The launch.json "API: FastAPI (uvicorn)"
# config sets this in env, so .env is not strictly required.
AUTH_DEV_BYPASS=true

# Real-token mode (uncomment + comment AUTH_DEV_BYPASS):
# API_CLIENT_ID=00000000-0000-0000-0000-000000000000
# API_AUDIENCE=api://elb-control

# --- Logging / docs ------------------------------------------------------
LOG_LEVEL=DEBUG
ENABLE_DOCS=true
MAX_REQUEST_BODY_BYTES=10485760

# --- Celery (matches the local "redis: ensure" task) ---------------------
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
OPS_REDIS_URL=redis://127.0.0.1:6379/2

# --- Terminal exec channel ----------------------------------------------
# Only needed if you run the terminal sidecar locally (compose.full).
# api/worker compare via hmac.compare_digest; min 16 chars or boot fails.
EXEC_TOKEN=dev-exec-token-not-secret-but-long-enough-for-startup-check
TERMINAL_EXEC_UPSTREAM=http://127.0.0.1:7682
TERMINAL_UPSTREAM=http://127.0.0.1:7681
FRONTEND_UPSTREAM=http://127.0.0.1:8081
